#define XK_MISCELLANY
#include <X11/keysymdef.h>

open Rtdecl;
open Util;
open Xlib;

type keysym =
  [ K_Ascii of char
  | K_Alt_L
  | K_Alt_R
  | K_BackSpace
  | K_Begin
  | K_Break
  | K_Cancel
  | K_Caps_Lock
  | K_Clear
  | K_Control_L
  | K_Control_R
  | K_Delete
  | K_Down
  | K_End
  | K_Escape
  | K_Execute
  | K_F of int
  | K_Find
  | K_Help
  | K_Home
  | K_Hyper_L
  | K_Hyper_R
  | K_Insert
  | K_KP_Add
  | K_KP_Decimal
  | K_KP_Divide
  | K_KP_Enter
  | K_KP_Equal
  | K_KP_F of int
  | K_KP_Multiply
  | K_KP_N of int
  | K_KP_Separator
  | K_KP_Space
  | K_KP_Subtract
  | K_KP_Tab
  | K_Left
  | K_Linefeed
  | K_Menu
  | K_Meta_L
  | K_Meta_R
  | K_Mode_switch
  | K_Multi_key
  | K_Next
  | K_Num_Lock
  | K_Pause
  | K_Print
  | K_Prior
  | K_Redo
  | K_Return
  | K_Right
  | K_Scroll_Lock
  | K_Select
  | K_Shift_L
  | K_Shift_Lock
  | K_Shift_R
  | K_Super_L
  | K_Super_R
  | K_Tab
  | K_Undo
  | K_Up
  | K_Other of int ]
;

value keysym_of_int =
  fun
  [ XK_Alt_L -> K_Alt_L
  | XK_Alt_R -> K_Alt_R
  | XK_BackSpace -> K_BackSpace
  | XK_Begin | XK_KP_Begin -> K_Begin
  | XK_Break -> K_Break
  | XK_Cancel -> K_Cancel
  | XK_Caps_Lock -> K_Caps_Lock
  | XK_Clear -> K_Clear
  | XK_Control_L -> K_Control_L
  | XK_Control_R -> K_Control_R
  | XK_Delete | XK_KP_Delete -> K_Delete
  | XK_Down | XK_KP_Down -> K_Down
  | XK_End | XK_KP_End -> K_End
  | XK_Escape -> K_Escape
  | XK_Execute -> K_Execute
  | XK_F1 -> K_F 1
  | XK_F10 -> K_F 10
  | XK_F11 -> K_F 11
  | XK_F12 -> K_F 12
  | XK_F13 -> K_F 13
  | XK_F14 -> K_F 14
  | XK_F15 -> K_F 15
  | XK_F16 -> K_F 16
  | XK_F17 -> K_F 17
  | XK_F18 -> K_F 18
  | XK_F19 -> K_F 19
  | XK_F2 -> K_F 2
  | XK_F20 -> K_F 20
  | XK_F21 -> K_F 21
  | XK_F22 -> K_F 22
  | XK_F23 -> K_F 23
  | XK_F24 -> K_F 24
  | XK_F25 -> K_F 25
  | XK_F26 -> K_F 26
  | XK_F27 -> K_F 27
  | XK_F28 -> K_F 28
  | XK_F29 -> K_F 29
  | XK_F3 -> K_F 3
  | XK_F30 -> K_F 30
  | XK_F31 -> K_F 31
  | XK_F32 -> K_F 32
  | XK_F33 -> K_F 33
  | XK_F34 -> K_F 34
  | XK_F35 -> K_F 35
  | XK_F4 -> K_F 4
  | XK_F5 -> K_F 5
  | XK_F6 -> K_F 6
  | XK_F7 -> K_F 7
  | XK_F8 -> K_F 8
  | XK_F9 -> K_F 9
  | XK_Find -> K_Find
  | XK_Help -> K_Help
  | XK_Home | XK_KP_Home -> K_Home
  | XK_Hyper_L -> K_Hyper_L
  | XK_Hyper_R -> K_Hyper_R
  | XK_Insert | XK_KP_Insert -> K_Insert
  | XK_KP_Add -> K_KP_Add
  | XK_KP_Decimal -> K_KP_Decimal
  | XK_KP_Divide -> K_KP_Divide
  | XK_KP_Enter -> K_KP_Enter
  | XK_KP_Equal -> K_KP_Equal
  | XK_KP_F1 -> K_KP_F 1
  | XK_KP_F2 -> K_KP_F 2
  | XK_KP_F3 -> K_KP_F 3
  | XK_KP_F4 -> K_KP_F 4
  | XK_KP_Multiply -> K_KP_Multiply
  | XK_KP_0 -> K_KP_N 0
  | XK_KP_1 -> K_KP_N 1
  | XK_KP_2 -> K_KP_N 2
  | XK_KP_3 -> K_KP_N 3
  | XK_KP_4 -> K_KP_N 4
  | XK_KP_5 -> K_KP_N 5
  | XK_KP_6 -> K_KP_N 6
  | XK_KP_7 -> K_KP_N 7
  | XK_KP_8 -> K_KP_N 8
  | XK_KP_9 -> K_KP_N 9
  | XK_KP_Separator -> K_KP_Separator
  | XK_KP_Space -> K_KP_Space
  | XK_KP_Subtract -> K_KP_Subtract
  | XK_KP_Tab -> K_KP_Tab
  | XK_Left | XK_KP_Left -> K_Left
  | XK_Linefeed -> K_Linefeed
  | XK_Menu -> K_Menu
  | XK_Meta_L -> K_Meta_L
  | XK_Meta_R -> K_Meta_R
  | XK_Mode_switch -> K_Mode_switch
  | XK_Multi_key -> K_Multi_key
  | XK_Next -> K_Next
  | XK_Num_Lock -> K_Num_Lock
  | XK_Pause -> K_Pause
  | XK_Print -> K_Print
  | XK_Prior -> K_Prior
  | XK_Redo -> K_Redo
  | XK_Return -> K_Return
  | XK_Right | XK_KP_Right -> K_Right
  | XK_Scroll_Lock -> K_Scroll_Lock
  | XK_Select -> K_Select
  | XK_Shift_L -> K_Shift_L
  | XK_Shift_Lock -> K_Shift_Lock
  | XK_Shift_R -> K_Shift_R
  | XK_Super_L -> K_Super_L
  | XK_Super_R -> K_Super_R
  | XK_Tab -> K_Tab
  | XK_Undo -> K_Undo
  | XK_Up | XK_KP_Up -> K_Up
